# Slack App (from api.slack.com → Your App → Basic Information)
NEXT_PUBLIC_SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (from dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Base $50/mo flat price. STRIPE_PRICE_ID is the legacy name (still read as fallback).
STRIPE_BASE_PRICE_ID=
STRIPE_PRICE_ID=
# Usage-metered overage price (graduated: first 20,000 credits $0, then $0.002/credit),
# tied to a Stripe Billing Meter with event name "sterling_credits".
STRIPE_METERED_PRICE_ID=

# Firebase (JSON string of service account key)
FIREBASE_SERVICE_ACCOUNT=

# Composio
COMPOSIO_API_KEY=

# Sterling backend (for Composio OAuth callbacks)
STERLING_APP_URL=https://sterling-agent-497252720926.us-east1.run.app
